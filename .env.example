# ── DATABASE ──────────────────────────────────────────────
# MariaDB connection string
DATABASE_URL="mysql://sycom_user:YOUR_DB_PASSWORD@localhost:3306/sycom_portal"

# ── NEXTAUTH ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"
NEXTAUTH_URL="https://portal.sycom.sk"

# ── SMTP EMAIL ─────────────────────────────────────────────
SMTP_HOST="mail.sycom.sk"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="portal@sycom.sk"
SMTP_PASSWORD="YOUR_SMTP_PASSWORD"
SMTP_FROM="Sycom IT Podpora <portal@sycom.sk>"

# ── APP ────────────────────────────────────────────────────
APP_NAME="Sycom IT Podpora"
APP_URL="https://portal.sycom.sk"
NEXT_PUBLIC_APP_NAME="Sycom IT Podpora"
NEXT_PUBLIC_APP_URL="https://portal.sycom.sk"

# ── FILE UPLOADS ───────────────────────────────────────────
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE_MB="10"
