// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
  CLIENT
  CLIENT_MANAGER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketCategory {
  HARDWARE
  SOFTWARE
  NETWORK
  EMAIL
  SECURITY
  CLOUD
  ONBOARDING
  OTHER
}

enum StockMovementType {
  BUY
  SELL
  RETURN_FROM_CUSTOMER
  RETURN_TO_SUPPLIER
  WRITEOFF
  CORRECTION
}

model Client {
  id             String          @id @default(cuid())
  name           String          @unique
  contactPerson  String?
  phone          String?
  ico            String?
  dic            String?
  dicDph         String?
  address        String?
  www            String?
  notes          String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  users          User[]
  tickets        Ticket[]
  pricing        ClientPricing[]
  stockMovements StockMovement[]
  manualHours    ManualHours[]
  @@map("clients")
  emailAlias     String?         @unique
  technicians    ClientTechnician[]
}

model ClientPricing {
  id           String   @id @default(cuid())
  clientId     String
  hoursType    String
  pricePerHour Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([clientId, hoursType])
  @@map("client_pricing")
}

model Supplier {
  id             String          @id @default(cuid())
  name           String          @unique
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  note           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
  priceList    SupplierPrice[]
  ico          String?
  dic          String?
  website      String?
  @@map("suppliers")
}

model StockItem {
  id           String          @id @default(cuid())
  name         String
  sku          String?         @unique
  category     String?
  unit         String          @default("ks")
  vatRate      Float           @default(20)
  minStock     Int             @default(0)
  currentStock Float           @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  movements    StockMovement[]
  description       String?   @db.Text
  location          String?
  photo             String?
  maxStock          Int       @default(0)
  avgPurchasePrice  Float     @default(0)
  lastPurchasePrice Float     @default(0)
  lastSalePrice     Float     @default(0)
  sellingPrice      Float     @default(0)
  serialTracking    Boolean   @default(false)
  supplierPrices    SupplierPrice[]
  serialNumbers     SerialNumber[]
  ticketUsages      TicketStockUsage[]
  @@map("stock_items")
}

model StockMovement {
  id           String            @id @default(cuid())
  type         StockMovementType
  stockItemId  String
  quantity     Float
  pricePerUnit Float             @default(0)
  totalPrice   Float             @default(0)
  vatRate      Float             @default(20)
  supplierId   String?
  clientId     String?
  addedById    String
  note         String?
  date         DateTime          @default(now())
  createdAt    DateTime          @default(now())
  stockItem    StockItem         @relation(fields: [stockItemId], references: [id])
  supplier     Supplier?         @relation(fields: [supplierId], references: [id])
  client       Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  addedBy      User              @relation(fields: [addedById], references: [id])
  supplierPriceId  String?
  serialNumber     String?
  invoiceNumber    String?
  @@map("stock_movements")
}

model ManualHours {
  id        String   @id @default(cuid())
  date      DateTime
  name      String
  hoursType String
  hours     Float
  userId    String
  clientId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  @@map("manual_hours")
}

model User {
  id              String       @id @default(cuid())
  name            String
  email           String       @unique
  password        String
  role            Role         @default(CLIENT)
  department      String?
  phone           String?
  avatar          String?
  isActive        Boolean      @default(true)
  clientId        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  client          Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  ticketsCreated  Ticket[]     @relation("TicketCreator")
  ticketsAssigned Ticket[]     @relation("TicketAssignee")
  comments        Comment[]
  teamMemberships TeamMember[]
  notifications   Notification[]
  sessions        Session[]
  stockMovements  StockMovement[]
  manualHours     ManualHours[]
  @@map("users")
  assignedClients      ClientTechnician[]
  auditLogs            AuditLog[]
  stockUsagesCreated   TicketStockUsage[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model Team {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  color       String       @default("#1a6fba")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     TeamMember[]
  tickets     Ticket[]
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  isLead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  @@unique([userId, teamId])
  @@map("team_members")
}

model Ticket {
  id            String         @id @default(cuid())
  ticketNumber  Int            @unique @default(autoincrement())
  subject       String
  description   String         @db.Text
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(MEDIUM)
  category      TicketCategory @default(OTHER)
  department    String?
  slaDeadline   DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  creatorId     String
  assigneeId    String?
  teamId        String?
  clientId      String?
  creator       User           @relation("TicketCreator", fields: [creatorId], references: [id])
  assignee      User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
  team          Team?          @relation(fields: [teamId], references: [id])
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  comments      Comment[]
  attachments   Attachment[]
  notifications Notification[]
  stockUsages   TicketStockUsage[]
  @@map("tickets")
}

model Comment {
  id          String   @id @default(cuid())
  body        String   @db.Text
  isInternal  Boolean  @default(false)
  workedHours Float    @default(0)
  hoursType   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ticketId    String
  authorId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id])
  @@map("comments")
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  @@map("attachments")
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  ticketId  String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket    Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  @@map("notifications")
}

model KbArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  body        String   @db.LongText
  category    String
  tags        String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("kb_articles")
}

model SupplierPrice {
  id            String     @id @default(cuid())
  stockItemId   String
  supplierId    String
  price         Float
  currency      String     @default("EUR")
  isPreferred   Boolean    @default(false)
  minOrderQty   Float?
  leadTimeDays  Int?
  supplierSku   String?
  note          String?
  validFrom     DateTime   @default(now())
  validTo       DateTime?
  lastUpdated   DateTime   @default(now())

  stockItem     StockItem  @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  supplier      Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([stockItemId, supplierId])
  @@map("supplier_prices")
}

model SerialNumber {
  id            String     @id @default(cuid())
  serialNumber  String     @unique
  stockItemId   String
  status        String     @default("IN_STOCK")
  purchaseDate  DateTime?
  saleDate      DateTime?
  clientId      String?
  note          String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  stockItem     StockItem  @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@map("serial_numbers")
}

model Setting {
  key   String @id
  value String @db.Text

  @@map("settings")
}

model ClientTechnician {
  clientId String
  userId   String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([clientId, userId])
  @@map("client_technicians")
}

model AllowedDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  note      String?
  createdAt DateTime @default(now())

  @@map("allowed_domains")
}

model SmtpSettings {
  id      Int     @id @default(1)
  host    String  @default("")
  port    Int     @default(587)
  secure  Boolean @default(false)
  user    String  @default("")
  pass    String  @default("")
  from    String  @default("")

  @@map("smtp_settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  oldValue   String?  @db.Text
  newValue   String?  @db.Text
  userId     String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model TicketStockUsage {
  id          String    @id @default(cuid())
  ticketId    String
  stockItemId String
  qty         Float
  note        String?
  createdAt   DateTime  @default(now())
  createdById String

  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@map("ticket_stock_usages")
}
